# Atlassian OAuth 2.0 (3LO) — from https://developer.atlassian.com/console/myapps/
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
# Must match the callback URL registered in Atlassian developer console
ATLASSIAN_CALLBACK_URL=http://localhost:8787/auth/atlassian/callback

# Allowed Jira Cloud instance
ALLOWED_JIRA_HOST=ytme.atlassian.net
# Optional: pin cloudId explicitly (recommended after first successful auth)
ALLOWED_JIRA_CLOUD_ID=

# Chrome extension ID (from chrome://extensions after Load unpacked, or fixed via manifest key)
EXTENSION_ID=

# Backend
PORT=8787
BACKEND_PUBLIC_URL=http://localhost:8787
SQLITE_PATH=./data/sessions.sqlite
SESSION_TTL_DAYS=7
CORS_EXTRA_ORIGINS=

# Comma-separated Jira status IDs treated as cancelled (optional)
CANCELLED_STATUS_IDS=

# Extension build-time (copied into extension via Vite define / env)
VITE_BACKEND_URL=http://localhost:8787
VITE_JIRA_HOST=ytme.atlassian.net
VITE_CANCELLED_STATUS_IDS=
